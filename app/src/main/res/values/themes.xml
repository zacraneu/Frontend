<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Front" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:statusBarColor">@color/background_light</item>
        <item name="android:navigationBarColor">@color/background_light</item>
    </style>

    <style name="Theme.Front.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_light</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Front</item>
    </style>
</resources>
